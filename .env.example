# 多链钱包 - 配置示例
# 复制此文件为 .env 并填入你的实际配置

# ====================
# 数据库配置
# ====================
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=wallet_db

# ====================
# API 配置
# ====================
# 后端 API 地址（移动端使用）
API_URL=https://your-api-domain.com

# 服务器域名（不包含协议）
SERVER_DOMAIN=your-api-domain.com

# ====================
# 加密密钥
# ====================
# 客户端加密密钥（用于加密助记词和私钥）
CLIENT_KEY=your_32_byte_client_key_here

# 服务器加密密钥（用于服务器端加密）
SERVER_KEY=your_32_byte_server_key_here

# ====================
# 区块链 RPC 节点
# ====================
# TRON 节点
TRON_GRID_API_KEY=your_trongrid_api_key
TRON_NODE_URL=https://api.trongrid.io

# Ethereum/BSC 节点
ETH_NODE_URL=https://eth-mainnet.g.alchemy.com/v2/your_api_key
BSC_NODE_URL=https://bsc-dataseed.binance.org

# ====================
# 其他配置
# ====================
# Flask 调试模式（生产环境设为 False）
FLASK_DEBUG=False

# 端口配置
FLASK_PORT=5000

# 管理员密码（如果有的话）
ADMIN_PASSWORD=your_admin_password
